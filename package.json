{
  "name": "@guilhermeseckert/query-store",
  "publishConfig": {
    "access": "public"
  },
  "version": "0.1.0",
  "description": "Thin, type-safe hierarchical query-key store for TanStack Query v5 — emits native queryOptions/infiniteQueryOptions with scoped _def handles for partial-key invalidation.",
  "author": "Guilherme Eckert (https://github.com/guilhermeseckert)",
  "license": "MIT",
  "packageManager": "pnpm@9.12.1",
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/guilhermeseckert/query-store.git"
  },
  "bugs": {
    "url": "https://github.com/guilhermeseckert/query-store/issues"
  },
  "homepage": "https://github.com/guilhermeseckert/query-store#readme",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --minify --clean",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:types": "tsc --noEmit -p tsconfig.json",
    "lint": "biome check src",
    "lint:fix": "biome check --write src",
    "format": "biome format --write src",
    "check": "pnpm run lint && pnpm run typecheck && pnpm run test",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish",
    "prepublishOnly": "pnpm run build"
  },
  "peerDependencies": {
    "@tanstack/react-query": ">=5.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@tanstack/react-query": "^5.101.0",
    "@vitest/coverage-v8": "^4.1.8",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.8"
  },
  "keywords": [
    "tanstack",
    "react-query",
    "query-key",
    "queryOptions",
    "cache",
    "typescript"
  ]
}